    <script>
        window.FrameworkConfig = {
            debugMode: <?= ($baseDTO->debugModeOn ?? false) ? 'true' : 'false' ?>,
            i18n: {
                themeDark: "<?= __('layout.theme_dark') ?>",

                themeLight: "<?= __('layout.theme_light') ?>"
            }
        };
    </script>

    <script>
        (function() {
            const savedTheme = localStorage.getItem('volt_theme');
            const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const theme = savedTheme || (systemPrefersDark ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

<script src="/js/volt/components/alerts.js" defer></script>
